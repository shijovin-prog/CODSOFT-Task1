!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Mobile App Signup UI</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:'Poppins',sans-serif;
}

body{
    background:#eef2ff;
    display:flex;
    justify-content:center;
    align-items:center;
    height:100vh;
}

.phone{
    width:360px;
    height:740px;
    background:#fff;
    border-radius:35px;
    box-shadow:0 20px 50px rgba(0,0,0,.2);
    overflow:hidden;
    position:relative;
}

.top{
    height:220px;
    background:linear-gradient(135deg,#6C63FF,#8E7BFF);
    border-bottom-left-radius:40px;
    border-bottom-right-radius:40px;
    color:white;
    display:flex;
    flex-direction:column;
    justify-content:center;
    align-items:center;
}

.logo{
    width:70px;
    height:70px;
    border-radius:20px;
    background:white;
    color:#6C63FF;
    display:flex;
    justify-content:center;
    align-items:center;
    font-size:30px;
    font-weight:bold;
    margin-bottom:15px;
}

.top h2{
    font-size:28px;
}

.top p{
    opacity:.8;
    font-size:14px;
}

.form{
    padding:30px;
}

.inputBox{
    margin-bottom:18px;
}

.inputBox label{
    display:block;
    font-size:13px;
    margin-bottom:8px;
    color:#666;
}

.inputBox input{
    width:100%;
    padding:15px;
    border:none;
    background:#f5f6fa;
    border-radius:15px;
    outline:none;
    font-size:15px;
    transition:.3s;
}

.inputBox input:focus{
    background:#edf0ff;
    border:2px solid #6C63FF;
}

.signupBtn{
    width:100%;
    padding:16px;
    border:none;
    border-radius:16px;
    background:#6C63FF;
    color:white;
    font-size:16px;
    cursor:pointer;
    transition:.3s;
    margin-top:10px;
}

.signupBtn:hover{
    background:#5548ff;
}

.divider{
    display:flex;
    align-items:center;
    margin:25px 0;
}

.divider::before,
.divider::after{
    content:"";
    flex:1;
    height:1px;
    background:#ddd;
}

.divider span{
    margin:0 12px;
    color:#888;
    font-size:13px;
}

.social{
    display:flex;
    justify-content:center;
    gap:15px;
}

.social button{
    width:60px;
    height:55px;
    border:none;
    border-radius:15px;
    background:#f5f6fa;
    font-size:22px;
    cursor:pointer;
    transition:.3s;
}

.social button:hover{
    background:#e8ebff;
}

.bottom{
    text-align:center;
    margin-top:25px;
    font-size:14px;
}

.bottom a{
    text-decoration:none;
    color:#6C63FF;
    font-weight:600;
}
</style>

</head>
<body>

<div class="phone">

<div class="top">
<div class="logo">S</div>
<h2>Create Account</h2>
<p>Join our community today</p>
</div>

<div class="form">

<div class="inputBox">
<label>Full Name</label>
<input type="text" placeholder="John Doe">
</div>

<div class="inputBox">
<label>Email</label>
<input type="email" placeholder="john@example.com">
</div>

<div class="inputBox">
<label>Password</label>
<input type="password" placeholder="••••••••">
</div>

<div class="inputBox">
<label>Confirm Password</label>
<input type="password" placeholder="••••••••">
</div>

<button class="signupBtn">
Create Account
</button>

<div class="divider">
<span>OR</span>
</div>

<div class="social">
<button>G</button>
<button></button>
<button>f</button>
</div>

<div class="bottom">
Already have an account?
<a href="#">Login</a>
</div>

</div>

</div>

</body>
</html>

